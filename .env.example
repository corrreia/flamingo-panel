# Better Auth secret — used for signing sessions/tokens
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Pocket ID OIDC credentials
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Cloudflare account ID — used to build R2 endpoint
CF_ACCOUNT_ID=

# R2 backup storage — used for presigned upload/download URLs
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
